# Based on GitHub's standard gitignore templates (Python + Node)
# https://github.com/github/gitignore

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editors
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files
.env
.env.*
!.env.example
!.env.*.example

# Python bytecode / extensions
__pycache__/
*.py[cod]
*$py.class
*.so
.python-version

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Python packaging
build/
dist/
site/
.eggs/
*.egg
*.egg-info/
pip-wheel-metadata/

# Virtual environments
venv/
.venv/
env/
ENV/
backend/.venv/

# Django local files
*.mo
local_settings.py
db.sqlite3
db.sqlite3-journal
backend/db.sqlite3
backend/db.sqlite3-journal
backend/staticfiles/
# Uncomment if user uploads are only local:
# backend/media/

# Frontend / Node.js
node_modules/
.npm/
.pnpm-store/
.pnp
.pnp.js
.parcel-cache/
.next/
.nuxt/
.svelte-kit/
coverage/
*.tsbuildinfo

# Yarn v2+
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite
frontend/.vite/
frontend/dist/
frontend/dist-ssr/

# Temporary files
*.tmp
*.temp

# Generated project artifacts
python_page1.md
python_split/
python_split_uk_ext_full4/
translate_all_ext_full4.log
scripts/
